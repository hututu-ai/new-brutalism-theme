    "editor.inactiveSelectionBackground": "#84cc1650",
    "editor.selectionHighlightBackground": "#c7e97a70",
    "editor.wordHighlightBackground": "#c7e97a80",
    "editor.wordHighlightStrongBackground": "#84cc16b0",
    "editor.lineHighlightBackground": "#84cc1610",
    "editor.lineHighlightBorder": "#000000",
    "editor.rangeHighlightBackground": "#84cc1640",
    "editor.findMatchBackground": "#84cc16",
    "editor.findMatchForeground": "#000000",
    "editor.findMatchHighlightBackground": "#c7e97a80",
    "editor.findRangeHighlightBackground": "#84cc1640",
    "editor.hoverHighlightBackground": "#84cc1630",
    "editor.linkedEditingBackground": "#c7e97a50",
    "editor.symbolHighlightBackground": "#c7e97a70",
