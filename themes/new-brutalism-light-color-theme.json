  "semanticHighlighting": true,
  "semanticTokenColors": {
    "newOperator": { "foreground": "#84cc16", "fontStyle": "bold" },
    "numberLiteral": { "foreground": "#fde047" },
    "stringLiteral": { "foreground": "#84cc16" },
    "type": { "foreground": "#000000", "fontStyle": "bold" },
    "parameter": { "foreground": "#000000" },
    "variable": { "foreground": "#000000" },
    "variable.declaration": { "foreground": "#000000" },
    "variable.readonly": { "foreground": "#84cc16" },
    "property": { "foreground": "#000000" },
    "enumMember": { "foreground": "#65a30d" },
    "namespace": { "foreground": "#000000", "fontStyle": "bold" },
    "function": { "foreground": "#000000", "fontStyle": "bold" },
    "method": { "foreground": "#000000", "fontStyle": "bold" },
    "member": { "foreground": "#000000" },
    "modifier": { "foreground": "#84cc16", "fontStyle": "bold" },
    "decorator": { "foreground": "#84cc16" },
    "interface": { "foreground": "#000000", "fontStyle": "bold" },
    "typeAlias": { "foreground": "#000000", "fontStyle": "bold" },
    "typeParameter": { "foreground": "#84cc16", "fontStyle": "bold" },
    "enum": { "foreground": "#000000", "fontStyle": "bold" },
    "event": { "foreground": "#fde047" },
    "label": { "foreground": "#888888" },
    "comment": { "foreground": "#999999", "fontStyle": "italic" },
    "keyword": { "foreground": "#84cc16", "fontStyle": "bold" },
    "macro": { "foreground": "#84cc16" },
    "class": { "foreground": "#000000", "fontStyle": "bold" }
  }
}
