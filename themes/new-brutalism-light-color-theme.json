    "tab.activeForeground": "#000000",
    "tab.activeBorder": "#84cc16",
    "tab.activeBorderTop": "#84cc16",
    "tab.activeModifiedBorder": "#fde047",
    "tab.inactiveBackground": "#ffffff",
    "tab.inactiveForeground": "#888888",
    "tab.inactiveModifiedBorder": "#fde04750",
    "tab.border": "#000000",
    "tab.hoverBackground": "#f7f7f7",
    "tab.hoverForeground": "#000000",
    "tab.hoverBorder": "#000000",
    "tab.unfocusedActiveBackground": "#f7f7f7",
    "tab.unfocusedActiveForeground": "#888888",
    "tab.unfocusedInactiveBackground": "#ffffff",
