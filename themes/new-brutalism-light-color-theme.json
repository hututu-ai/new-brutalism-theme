    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#84cc16"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#fde047"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#dc2626"
      }
    },
    {
      "scope": [
        "markup.separator",
        "meta.separator"
