    "list.activeSelectionForeground": "#ffffff",
    "list.inactiveSelectionBackground": "#e0e0e0",
    "list.inactiveSelectionForeground": "#000000",
    "list.hoverBackground": "#f7f7f7",
    "list.hoverForeground": "#000000",
    "list.highlightForeground": "#65a30d",
    "list.focusBackground": "#c7e97a30",
    "list.focusForeground": "#000000",
    "list.focusOutline": "#000000",
    "list.dropBackground": "#c7e97a15",
    "list.errorForeground": "#dc2626",
    "list.warningForeground": "#fde047",
    "listFilterWidget.background": "#ffffff",
    "listFilterWidget.outline": "#84cc16",
    "listFilterWidget.noMatchesOutline": "#dc2626",
    "tree.indentGuidesStroke": "#00000030",

    /* ── Scrollbar ── */
    "scrollbar.shadow": "#000000",
    "scrollbarSlider.background": "#00000020",
    "scrollbarSlider.hoverBackground": "#00000040",
    "scrollbarSlider.activeBackground": "#00000060",

    /* ── Focus ── */
    "focusBorder": "#84cc16",

    /* ── Widget ── */
    "widget.border": "#000000",
    "widget.shadow": "#000000",

    /* ── Badge ── */
    "badge.background": "#84cc16",
    "badge.foreground": "#000000",

    /* ── Progress Bar ── */
    "progressBar.background": "#84cc16",

    /* ── Notification ── */
    "notificationCenter.border": "#000000",
    "notificationCenterHeader.background": "#ffffff",
    "notificationCenterHeader.border": "#000000",
    "notificationCenterHeader.foreground": "#000000",
    "notificationToast.border": "#000000",
    "notifications.background": "#ffffff",
    "notifications.border": "#000000",
    "notifications.foreground": "#000000",
    "notificationLink.foreground": "#84cc16",

    /* ── Banner ── */
    "banner.background": "#ffffff",
    "banner.foreground": "#000000",
    "banner.iconForeground": "#84cc16",

    /* ── Terminal (light background to match editor) ── */
    "terminal.background": "#f7f7f7",
    "terminal.foreground": "#000000",
    "terminal.border": "#000000",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#dc2626",
    "terminal.ansiGreen": "#84cc16",
    "terminal.ansiYellow": "#ca8a04",
    "terminal.ansiBlue": "#2563eb",
    "terminal.ansiMagenta": "#9333ea",
    "terminal.ansiCyan": "#0891b2",
    "terminal.ansiWhite": "#d4d4d4",
    "terminal.ansiBrightBlack": "#888888",
    "terminal.ansiBrightRed": "#ef4444",
    "terminal.ansiBrightGreen": "#65a30d",
    "terminal.ansiBrightYellow": "#ca8a04",
    "terminal.ansiBrightBlue": "#3b82f6",
    "terminal.ansiBrightMagenta": "#a855f7",
    "terminal.ansiBrightCyan": "#06b6d4",
    "terminal.ansiBrightWhite": "#ffffff",
    "terminalCursor.background": "#000000",
    "terminalCursor.foreground": "#84cc16",
    "terminal.selectionBackground": "#84cc1640",

    /* ── Debug ── */
    "debugToolBar.background": "#ffffff",
    "debugToolBar.border": "#000000",
    "debugExceptionWidget.background": "#dc2626",
    "debugExceptionWidget.border": "#000000",
    "debugIcon.startForeground": "#84cc16",
    "debugIcon.pauseForeground": "#fde047",
    "debugIcon.stopForeground": "#dc2626",
    "debugIcon.disconnectForeground": "#888888",
    "debugIcon.continueForeground": "#84cc16",
    "debugIcon.stepOverForeground": "#60a5fa",
    "debugIcon.stepIntoForeground": "#60a5fa",
    "debugIcon.stepOutForeground": "#60a5fa",

    /* ── Diff Editor ── */
    "diffEditor.insertedTextBackground": "#84cc1620",
    "diffEditor.removedTextBackground": "#dc262620",
    "diffEditor.border": "#000000",
    "diffEditor.diagonalFill": "#00000015",

    /* ── Merge ── */
    "merge.currentHeaderBackground": "#84cc1640",
    "merge.incomingHeaderBackground": "#60a5fa40",
    "merge.border": "#000000",
    "merge.commonContentBackground": "#99999920",
    "merge.commonHeaderBackground": "#99999940",
    "editorOverviewRuler.currentContentForeground": "#84cc16",
    "editorOverviewRuler.incomingContentForeground": "#60a5fa",
    "editorOverviewRuler.commonContentForeground": "#999999",

    /* ── Git Decorations ── */
    "gitDecoration.addedResourceForeground": "#84cc16",
    "gitDecoration.modifiedResourceForeground": "#fde047",
    "gitDecoration.deletedResourceForeground": "#dc2626",
    "gitDecoration.renamedResourceForeground": "#60a5fa",
    "gitDecoration.untrackedResourceForeground": "#84cc16",
    "gitDecoration.ignoredResourceForeground": "#bbbbbb",
    "gitDecoration.stageModifiedResourceForeground": "#fde047",
    "gitDecoration.stageDeletedResourceForeground": "#dc2626",
    "gitDecoration.conflictingResourceForeground": "#f97316",
    "gitDecoration.submoduleResourceForeground": "#c084fc",

    /* ── Inline Chat ── */
    "inlineChat.background": "#ffffff",
    "inlineChat.border": "#000000",
    "inlineChat.foreground": "#000000",
    "inlineChatInput.background": "#f7f7f7",
    "inlineChatInput.border": "#000000",

    /* ── Chat (Copilot) ── */
    "chat.requestBackground": "#f7f7f7",
    "chat.requestBorder": "#000000",
    "chat.slashCommandBackground": "#84cc1620",
    "chat.slashCommandForeground": "#84cc16",

    /* ── Minimap ── */
    "minimap.background": "#ffffff",
    "minimap.selectionHighlight": "#84cc1650",
    "minimap.findMatchHighlight": "#84cc16",
    "minimap.errorHighlight": "#dc2626",
    "minimap.warningHighlight": "#fde047",
    "minimapGutter.addedBackground": "#84cc16",
    "minimapGutter.modifiedBackground": "#fde047",
    "minimapGutter.deletedBackground": "#dc2626",

    /* ── Breadcrumbs ── */
    "breadcrumb.foreground": "#888888",
    "breadcrumb.background": "#f7f7f7",
    "breadcrumb.focusForeground": "#000000",
    "breadcrumb.activeSelectionForeground": "#000000",
    "breadcrumbPicker.background": "#ffffff",

    /* ── Extension buttons ── */
    "extensionButton.prominentBackground": "#84cc16",
    "extensionButton.prominentForeground": "#000000",
    "extensionButton.prominentHoverBackground": "#6aad12",
    "extensionButton.background": "#000000",
    "extensionButton.foreground": "#ffffff",
    "extensionButton.hoverBackground": "#222222",

    /* ── Welcome / Getting Started ── */
    "welcomePage.background": "#f7f7f7",
    "welcomePage.progress.background": "#ffffff",
    "welcomePage.tileBackground": "#ffffff",
    "welcomePage.tileBorder": "#000000",
    "welcomePage.tileShadow": "#000000",
    "walkThrough.embeddedEditorBackground": "#ffffff",

    /* ── Keybinding Label ── */
    "keybindingLabel.background": "#ffffff",
    "keybindingLabel.border": "#000000",
    "keybindingLabel.bottomBorder": "#000000",
    "keybindingLabel.foreground": "#000000",

    /* ── Settings ── */
    "settings.headerForeground": "#000000",
    "settings.modifiedItemIndicator": "#fde047",
    "settings.dropdownBackground": "#ffffff",
    "settings.dropdownBorder": "#000000",
    "settings.dropdownForeground": "#000000",
    "settings.checkboxBackground": "#ffffff",
    "settings.checkboxBorder": "#000000",
    "settings.checkboxForeground": "#000000",
    "settings.textInputBackground": "#ffffff",
    "settings.textInputBorder": "#000000",
    "settings.textInputForeground": "#000000",
    "settings.numberInputBackground": "#ffffff",
    "settings.numberInputBorder": "#000000",
    "settings.numberInputForeground": "#000000",

    /* ── SCM ── */
    "scm.providerBorder": "#000000",

    /* ── Notebook ── */
    "notebook.cellBorderColor": "#000000",
    "notebook.cellHoverBackground": "#ffffff",
    "notebook.cellInsertionDecoration": "#84cc16",
    "notebook.cellStatusBarItemHoverBackground": "#00000015",
    "notebook.cellToolbarSeparator": "#000000",
    "notebook.focusedCellBorder": "#84cc16",
    "notebook.focusedEditorBorder": "#84cc16",
    "notebook.outputContainerBackgroundColor": "#ffffff",
    "notebook.outputContainerBorderColor": "#000000",
    "notebook.selectedCellBackground": "#c7e97a15",
    "notebook.selectedCellBorder": "#000000",
    "notebook.symbolHighlightBackground": "#c7e97a40",
    "notebookScrollbarSlider.background": "#00000020",
    "notebookScrollbarSlider.hoverBackground": "#00000040",
    "notebookScrollbarSlider.activeBackground": "#00000060",
    "notebookStatusErrorIcon.foreground": "#dc2626",
    "notebookStatusRunningIcon.foreground": "#fde047",
    "notebookStatusSuccessIcon.foreground": "#84cc16",

    /* ── Editor Stacks ── */
    "editorMarkerNavigation.background": "#ffffff",
    "editorMarkerNavigationError.background": "#dc2626",
    "editorMarkerNavigationWarning.background": "#fde047",
    "editorMarkerNavigationInfo.background": "#84cc16",

    /* ── Peek View ── */
    "peekView.border": "#000000",
    "peekViewEditor.background": "#f7f7f7",
    "peekViewEditor.matchHighlightBackground": "#c7e97a40",
    "peekViewResult.background": "#ffffff",
    "peekViewResult.fileForeground": "#000000",
    "peekViewResult.lineForeground": "#888888",
    "peekViewResult.matchHighlightBackground": "#c7e97a",
    "peekViewResult.selectionBackground": "#000000",
    "peekViewResult.selectionForeground": "#ffffff",
    "peekViewTitle.background": "#ffffff",
    "peekViewTitleDescription.foreground": "#888888",
    "peekViewTitleLabel.foreground": "#000000",

    /* ── Quick Input ── */
    "quickInput.background": "#ffffff",
    "quickInput.foreground": "#000000",
    "quickInput.list.focusBackground": "#000000",
    "quickInput.list.focusForeground": "#ffffff",
    "quickInputTitle.background": "#ffffff",

    /* ── Image Preview ── */
    "imagePreview.border": "#000000",

    /* ── Accessibility ── */
    "accessibilityBar.background": "#84cc16",
    "accessibilityBar.foreground": "#000000"
  },
  "tokenColors": [
    /* ── Comments ── */
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.line.double-slash",
        "comment.line.number-sign",
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#999999",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#999999",
        "fontStyle": "italic"
      }
    },

    /* ── Keywords (Lime Green, Bold — 新粗野风核心色) ── */
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.return",
        "keyword.control.if",
        "keyword.control.else",
        "keyword.control.switch",
        "keyword.control.case",
        "keyword.control.default",
        "keyword.control.break",
        "keyword.control.continue",
        "keyword.control.for",
        "keyword.control.while",
        "keyword.control.do",
        "keyword.control.try",
        "keyword.control.catch",
        "keyword.control.finally",
        "keyword.control.throw",
        "keyword.control.raise",
        "keyword.control.with",
        "keyword.control.yield",
        "keyword.control.as",
        "keyword.control.from",
        "keyword.control.class",
        "keyword.control.def",
        "keyword.control.lambda",
        "keyword.control.new",
        "keyword.control.delete",
        "keyword.control.in",
        "keyword.control.of",
        "keyword.control.where",
        "keyword.control.let",
        "keyword.control.var",
        "keyword.control.const",
        "keyword.control.type",
        "keyword.control.typeof",
        "keyword.control.instanceof",
        "keyword.control.keyof",
        "keyword.other",
        "keyword.other.important"
      ],
      "settings": {
        "foreground": "#84cc16",
        "fontStyle": "bold"
      }
    },

    /* ── Storage (Lime Green Bold) ── */
    {
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier",
        "storage.type.class",
        "storage.type.function",
        "storage.type.interface",
        "storage.type.enum",
        "storage.type.primitive",
        "storage.type.utility"
      ],
      "settings": {
        "foreground": "#84cc16",
        "fontStyle": "bold"
      }
    },

    /* ── Constants / Literals (Lime Green) ── */
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#84cc16",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nil",
        "constant.language.none",
        "constant.language.true",
        "constant.language.false"
      ],
      "settings": {
        "foreground": "#84cc16",
        "fontStyle": "bold"
      }
    },

    /* ── Numbers (Yellow) ── */
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary",
        "constant.numeric.decimal"
      ],
      "settings": {
        "foreground": "#fde047"
      }
    },

    /* ── Strings (Lime Green) ── */
    {
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.quoted.other",
        "string.unquoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#84cc16"
      }
    },
    {
      "scope": [
        "string.regexp",
        "string.regexp.character-class"
      ],
      "settings": {
        "foreground": "#84cc16"
      }
    },
    {
      "scope": [
        "string.interpolation",
        "string.template.variable",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#65a30d"
      }
    },
    {
      "scope": [
        "string.key",
        "string.key.json",
        "string.key.yaml"
      ],
      "settings": {
        "foreground": "#65a30d"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#84cc16"
      }
    },

    /* ── Escape Characters (Yellow) ── */
    {
      "scope": [
        "constant.character.escape",
        "constant.character.code"
      ],
      "settings": {
        "foreground": "#fde047"
      }
    },

    /* ── Functions (Black Bold) ── */
    {
      "scope": [
        "entity.name.function",
        "entity.name.function.constructor",
        "entity.name.function.method",
        "entity.name.function.decorator",
        "entity.name.function.macro",
        "entity.name.function.special"
      ],
      "settings": {
        "foreground": "#000000",
        "fontStyle": "bold"
      }
    },

    /* ── Built-in Functions (Lime Green) ── */
    {
      "scope": [
        "support.function",
        "support.function.console",
        "support.function.builtin",
        "support.function.magic"
      ],
      "settings": {
        "foreground": "#84cc16",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "meta.function-call",
        "meta.method-call"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "scope": [
        "punctuation.definition.parameters",
        "punctuation.definition.parameters.begin",
        "punctuation.definition.parameters.end"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },

    /* ── Types / Classes (Black Bold) ── */
    {
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.typedef",
        "entity.name.type.alias",
        "entity.name.type.module",
        "support.type",
        "support.type.primitive",
        "support.type.builtin",
        "meta.type"
      ],
      "settings": {
        "foreground": "#000000",
        "fontStyle": "bold"
      }
    },

    /* ── Tags (Black) ── */
    {
      "scope": [
        "entity.name.tag",
        "entity.name.tag.block",
        "entity.name.tag.inline",
        "entity.name.tag.script",
        "entity.name.tag.style",
        "entity.name.tag.doctype",
        "meta.tag"
