    /* ── Panel ── */
    "panel.background": "#f7f7f7",
    "panel.border": "#000000",
    "panelTitle.activeBorder": "#84cc16",
    "panelTitle.activeForeground": "#000000",
    "panelTitle.inactiveForeground": "#888888",
    "panelInput.border": "#000000",
    "panelSection.border": "#000000",
