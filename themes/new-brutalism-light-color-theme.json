    /* ── Input Controls ── */
    "input.background": "#ffffff",
    "input.border": "#000000",
    "input.foreground": "#000000",
    "input.placeholderForeground": "#999999",
    "inputOption.activeBackground": "#000000",
    "inputOption.activeBorder": "#000000",
    "inputOption.activeForeground": "#ffffff",
    "inputValidation.errorBackground": "#dc2626",
    "inputValidation.errorBorder": "#000000",
    "inputValidation.errorForeground": "#ffffff",
    "inputValidation.infoBackground": "#84cc16",
    "inputValidation.infoBorder": "#000000",
    "inputValidation.warningBackground": "#fde047",
